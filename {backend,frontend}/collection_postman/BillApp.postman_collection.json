              ],
              "type": "text/javascript"
            }
          }],
          "request": {
            "method": "GET",
            "header": [{ "key": "Authorization", "value": "Bearer {{token}}" }],
            "url": { "raw": "{{baseUrl}}/api/bills/{{billId}}", "host": ["{{baseUrl}}"], "path": ["api","bills","{{billId}}"] }
          }
        },

        {
