        },

        {
          "name": "Delete Bill (not found) ❌",
          "event": [{
            "listen": "test",
            "script": {
              "exec": [
                "pm.test('Status 400 for missing bill', () => pm.response.to.have.status(400));"
              ],
              "type": "text/javascript"
            }
          }],
          "request": {
            "method": "DELETE",
            "header": [{ "key": "Authorization", "value": "Bearer {{token}}" }],
            "url": { "raw": "{{baseUrl}}/api/bills/99999", "host": ["{{baseUrl}}"], "path": ["api","bills","99999"] }
          }
        }

      ]
    },

    {
      "name": "🧪 End-to-End Flow",
      "item": [

        {
